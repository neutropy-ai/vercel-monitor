# Neutropy Vercel Monitor — Environment Variables
# Copy to .env.local for local development
# Set all of these in Vercel dashboard → Settings → Environment Variables

# ─── Vercel API ───────────────────────────────────────────────────────────────
# Create at: https://vercel.com/account/tokens
VERCEL_API_TOKEN=your_vercel_api_token_here

# Your Vercel team ID (find in team settings URL)
# Leave empty if using a personal account
VERCEL_TEAM_ID=

# Secret for verifying webhook signatures
# Set this in Vercel when creating the webhook, then copy it here
VERCEL_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Upstash Redis (replaces Vercel KV, which is now sunset) ─────────────────
# Install from: Vercel Dashboard → Storage → Browse Marketplace → Upstash Redis
# Vercel auto-sets these when you link the database to this project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── GHL WhatsApp ─────────────────────────────────────────────────────────────
# GHL API key from Settings → API Keys
GHL_API_TOKEN=your_ghl_api_token_here

# GHL Location ID (find in GHL → Settings → Business Info)
GHL_LOCATION_ID=your_location_id_here

# Luke's WhatsApp number (must be registered in GHL contacts)
LUKE_PHONE=+353857746900

# ─── Monitor ──────────────────────────────────────────────────────────────────
# Comma-separated list of Vercel project names to watch (production only)
# Leave empty during active development. Add a project name when it goes live.
# Find project names in Vercel dashboard → Project Settings → General → Project Name
# Example: funkytown-middleware,slides-two-silk,charter-middleware
WATCHED_PROJECTS=

# The public URL of this deployed monitor (no trailing slash)
MONITOR_BASE_URL=https://neutropy-monitor.vercel.app

# Secret for protecting the cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here
